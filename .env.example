# ── Server ────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────
# Leave empty to use the persistent in-memory MongoDB fallback
MONGODB_URI=

# ── Authentication ────────────────────────────────────────
# Required. Use a long, random string (minimum 32 characters).
#   Linux/macOS:  openssl rand -hex 32
#   Windows:      Use an online generator or a UUID library
JWT_SECRET=change_me_to_a_random_secret

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production this MUST be set (the app will refuse to start).
CORS_ORIGINS=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────
# Leave RESEND_API_KEY unset to disable email sending
RESEND_API_KEY=
EMAIL_FROM=WannaOut <noreply@wannaout.app>

# ── Environment ───────────────────────────────────────────
# "development" or "production"
NODE_ENV=development

# ── Sentry (optional — leave unset to disable error tracking) ─────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
LOG_LEVEL=info
